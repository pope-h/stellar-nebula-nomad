# ─── Nebula Nomad: Resource Minter Configuration ─────────────────────────────
#
# Copy this file to .env and fill in values before deploying.
# All numeric rate values can be updated on-chain after deployment via
# the admin functions update_daily_cap() and update_apy().
# ─────────────────────────────────────────────────────────────────────────────

# ── Yield / APY ───────────────────────────────────────────────────────────────

# Annual Percentage Yield expressed in basis points.
# 100 bps = 1 %, so 500 = 5 % APY (default).
# This is the rate at which staked resources earn cosmic essence (Plasma).
STARDUST_APY_BPS=500

# ── Harvest caps ──────────────────────────────────────────────────────────────

# Maximum stardust units a single ship can harvest per ~24-hour ledger window.
# One unit = 1 stardust (the base mint is 100 per anomaly).
# Tune this to control inflation; lower values = scarcer economy.
DAILY_HARVEST_CAP=1000

# Base stardust awarded per harvest call before rarity bonus.
# Final amount = STARDUST_PER_ANOMALY + anomaly_index * 10
STARDUST_PER_ANOMALY=100

# ── Staking time-lock ─────────────────────────────────────────────────────────

# Minimum number of ledgers a stake must be held before unstake is permitted.
# At ~5 s/ledger on Stellar: 17280 ledgers ≈ 24 hours (1 day).
# Increase to require longer lock-up (e.g. 86400 ≈ 5 days).
MIN_STAKE_DURATION_LEDGERS=17280

# ── Contract addresses ────────────────────────────────────────────────────────

# Soroban contract ID of the deployed Ship Registry (NFT) contract.
# Used for cross-contract ownership verification during harvest.
SHIP_CONTRACT_ID=

# Soroban contract ID of the deployed Nebula Explorer (generation) contract.
# Used for cross-contract anomaly validation during harvest.
NEBULA_CONTRACT_ID=

# ── Deployment credentials ────────────────────────────────────────────────────

# Stellar account secret key of the contract admin.
# WARNING: Never commit a real secret key to version control.
ADMIN_SECRET_KEY=

# Stellar network passphrase.
# Futurenet: "Test SDF Future Network ; October 2022"
# Testnet:   "Test SDF Network ; September 2015"
# Mainnet:   "Public Global Stellar Network ; September 2015"
STELLAR_NETWORK_PASSPHRASE="Test SDF Future Network ; October 2022"

# Soroban RPC endpoint.
# Futurenet: https://rpc-futurenet.stellar.org
# Testnet:   https://soroban-testnet.stellar.org
SOROBAN_RPC_URL=https://rpc-futurenet.stellar.org
